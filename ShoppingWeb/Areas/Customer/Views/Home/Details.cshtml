@model ShoppingCart

<form method="post">
    <input type="hidden" asp-for="ProductId" />

    <div class="container mt-4">
        <div class="row">

            <!-- LEFT: IMAGE -->
            <div class="col-lg-4 text-center">
                <div class="card p-3 shadow-sm border-0">
                    <img src="@Model.Product.ImageUrl" class="img-fluid rounded" style="max-height:350px;" />

                    <div class="mt-3 d-grid gap-2">
                        <button type="submit" class="btn btn-warning fw-bold">
                            🛒 Add to Cart
                        </button>
                        <button type="button" class="btn btn-danger fw-bold">
                            ⚡ Buy Now
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT: DETAILS -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 p-4">

                    <h4 class="fw-bold">@Model.Product.Title</h4>
                    <p class="text-muted mb-1">by @Model.Product.Author</p>

                    <!-- Rating -->
                    <span class="badge bg-success">4.3 ★</span>

                    <hr />

                    <!-- Price Section -->
                    <h3 class="text-success fw-bold">
                        @Model.Product.Price.ToString("c")
                    </h3>

                    <p class="text-muted">
                        MRP:
                        <span class="text-decoration-line-through">
                            @Model.Product.ListPrice.ToString("c")
                        </span>
                    </p>

                    <p class="text-success fw-semibold">10% off</p>

                    <!-- Quantity -->
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label class="fw-semibold">Quantity</label>
                            <input asp-for="Count" type="number" value="1" class="form-control" />
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="mt-4">
                        <h5 class="fw-bold">Product Description</h5>
                        <p class="text-secondary">@Model.Product.Description</p>
                    </div>

                    <!-- Category -->
                    <div class="mt-3">
                        <span class="badge bg-primary">@Model.Product.Category.CategoryName</span>
                    </div>

                </div>
            </div>

        </div>
    </div>
</form>