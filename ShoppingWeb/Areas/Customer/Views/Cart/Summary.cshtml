@model Shopping_Models.ViewModels.ShoppingCartVM

<form method="post" asp-action="Summary">
    @Html.AntiForgeryToken()

    <div class="container mt-4">
        <div class="row">

            <!-- LEFT: SHIPPING DETAILS -->
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">

                        <h5 class="mb-3 fw-bold text-primary">Shipping Details</h5>

                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input asp-for="OrderHeader.Name" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <input asp-for="OrderHeader.PhoneNumber" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Street Address</label>
                            <input asp-for="OrderHeader.StreetAddress" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">City</label>
                                <input asp-for="OrderHeader.City" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">State</label>
                                <input asp-for="OrderHeader.State" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Postal Code</label>
                            <input asp-for="OrderHeader.PostalCode" class="form-control" />
                        </div>

                    </div>
                </div>
            </div>

            <!-- RIGHT: ORDER SUMMARY -->
            <div class="col-lg-5">
                <div class="card shadow border-0 sticky-top" style="top:80px;">
                    <div class="card-body">

                        <h5 class="fw-bold mb-3">Order Summary</h5>

                        @foreach (var item in Model.ShoppingCartList)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <div>
                                    <h6 class="mb-0">@item.Product.Title</h6>
                                    <small class="text-muted">Qty: @item.Count</small>
                                </div>
                                <span>@(item.Price* item.Count)</span>
                            </div>
                        }

                        <hr />

                        <div class="d-flex justify-content-between">
                            <span>Subtotal</span>
                            <span>@Model.OrderHeader.OrderTotal.ToString("c")</span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Delivery</span>
                            <span class="text-success">FREE</span>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total</span>
                            <span>@Model.OrderHeader.OrderTotal.ToString("c")</span>
                        </div>

                        <!-- ✅ SUBMIT BUTTON -->
                        <button type="submit" class="btn btn-warning w-100 mt-3 fw-bold">
                            Place Order
                        </button>

                    </div>
                </div>
            </div>

        </div>
    </div>
</form>