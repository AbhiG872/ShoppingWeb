@model int

<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card shadow-lg p-5 text-center" style="max-width:600px; border-radius:20px;">

        <!-- SUCCESS ICON -->
        <div class="mb-3">
            <i class="bi bi-check-circle-fill text-success" style="font-size:70px;"></i>
        </div>

        <!-- TITLE -->
        <h2 class="text-success fw-bold">Order Placed Successfully 🎉</h2>

        <!-- ORDER NUMBER -->
        <p class="mt-3 fs-5">
            Your Order Number is:
            <span class="fw-bold text-primary">#@Model</span>
        </p>

        <!-- IMAGE (FIXED PATH) -->
        <img src="~/images/order-success.png" class="img-fluid my-3" style="max-height:200px;" />

        <!-- MESSAGE -->
        <p class="text-muted">
            Thank you for your purchase! Your order is being processed and will be shipped soon.
        </p>

        <!-- BUTTON -->
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3 px-4">
            Continue Shopping
        </a>

    </div>
</div>