@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-wrapper">

    <div class="auth-card shadow-lg">

        <!-- Logo / Title -->
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">ShoppingWeb</h2>
            <p class="text-muted">Create your account 🚀</p>
        </div>

        <form method="post">

            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                <label>Email</label>
            </div>

            <!-- Name + Address -->
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Name" class="form-control" placeholder="Name" />
                        <label>Name</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.StreetAddress" class="form-control" placeholder="Street Address" />
                        <label>Street Address</label>
                    </div>
                </div>
            </div>

            <!-- City + State -->
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.City" class="form-control" placeholder="City" />
                        <label>City</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.State" class="form-control" placeholder="State" />
                        <label>State</label>
                    </div>
                </div>
            </div>

            <!-- Postal + Role -->
            <div class="row">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.PostalCode" class="form-control" placeholder="Postal Code" />
                        <label>Postal Code</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select">
                            <option value="">Select Role</option>
                        </select>
                        <label>Role</label>
                    </div>
                </div>
            </div>

            <!-- Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                <label>Password</label>
            </div>

            <!-- Confirm Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                <label>Confirm Password</label>
            </div>

            <!-- Button -->
            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                Create Account
            </button>

            <!-- Login -->
            <p class="text-center mt-3 mb-0">
                Already have an account?
                <a asp-page="./Login" class="fw-semibold text-decoration-none">Login</a>
            </p>

        </form>

    </div>

</div>