@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">

    <!-- LEFT SIDE -->
    <div class="auth-left">
        <div class="brand-box">
            <h1>ShoppingWeb</h1>
            <p>Build your shopping experience 🚀</p>
        </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="auth-right">
        <div class="auth-card">

            <h2 class="mb-3">Create Account</h2>

            <form method="post">

                <div asp-validation-summary="All" class="text-danger"></div>

                <!-- Email -->
                <input asp-for="Input.Email" class="form-control mb-2" placeholder="Email" />

                <!-- Name -->
                <input asp-for="Input.Name" class="form-control mb-2" placeholder="Full Name" />

                <!-- Phone + Address -->
                <div class="row">
                    <div class="col-md-6">
                        <input asp-for="Input.PhoneNumber" class="form-control mb-2" placeholder="Phone Number" />
                    </div>
                    <div class="col-md-6">
                        <input asp-for="Input.StreetAddress" class="form-control mb-2" placeholder="Street Address" />
                    </div>
                </div>

                <!-- City + State -->
                <div class="row">
                    <div class="col-md-6">
                        <input asp-for="Input.City" class="form-control mb-2" placeholder="City" />
                    </div>
                    <div class="col-md-6">
                        <input asp-for="Input.State" class="form-control mb-2" placeholder="State" />
                    </div>
                </div>

                <!-- Postal + Role -->
                <div class="row">
                    <div class="col-md-6">
                        <input asp-for="Input.PostalCode" class="form-control mb-2" placeholder="Postal Code" />
                    </div>
                    <div class="col-md-6">
                        <select id="roleSelect" asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select mb-2">
                            <option value="">Select Role</option>
                        </select>
                    </div>
                </div>

                <!-- Company (Hidden by default) -->
                <div class="row" id="companyDiv" style="display:none;">
                    <div class="col-md-12">
                        <select asp-for="Input.CompanyId" asp-items="@Model.Input.CompanyList" class="form-select mb-2">
                            <option value="">Select Company</option>
                        </select>
                    </div>
                </div>

                <!-- Password -->
                <input asp-for="Input.Password" type="password" class="form-control mb-2" placeholder="Password" />

                <!-- Confirm -->
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control mb-3" placeholder="Confirm Password" />

                <button type="submit" class="btn btn-primary w-100">Register</button>

                <p class="mt-3 text-center">
                    Already have an account?
                    <a asp-page="./Login">Login</a>
                </p>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const roleSelect = document.getElementById("roleSelect");
        const companyDiv = document.getElementById("companyDiv");

        roleSelect.addEventListener("change", function () {
            if (this.value === "Company" || this.value === "Employee") {
                companyDiv.style.display = "block";
            } else {
                companyDiv.style.display = "none";
            }
        });
    </script>
}