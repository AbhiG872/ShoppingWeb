@model IEnumerable<ShoppingWeb.Models.Category>

<h4 class="mb-3">Category List</h4>
<a asp-action="Create" class="btn btn-sm btn-primary mb-3">
    <i class="bi bi-pencil-square"></i> Create
</a>
    <br />


    <table class="table table-bordered table-striped">
    <thead>
        <tr>
        <th>Category Name</th>
           <th>Display Order</th>
           <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.CategoryName</td>
            <td>@item.DisplayOrder</td>
            <td>
                    <a asp-action="Edit" class="btn btn-primary"asp-route-id="@item.Id">Edit</a>
                    <a asp-action="Details" class="btn btn-secondary" asp-route-id="@item.Id">Details</a>
                    <a asp-action="Delete" class="btn btn-danger" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>